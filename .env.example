# ─── Supabase ───
# Supabase 프로젝트 > Settings > API 에서 복사
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# RLS를 우회하는 서버 전용 키 (API 라우트에서 사용)
# 절대 NEXT_PUBLIC_ 접두사 붙이지 말 것
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── 성능 최적화: Connection Pooler ───
# Vercel(서버리스) 환경에서 매 요청마다 새 DB 연결 만드는 오버헤드(100~300ms) 제거.
# Supabase Dashboard > Settings > Database > Connection pooling 에서 복사.
# Transaction mode 권장 (port 6543).
# 사용하려면 위 NEXT_PUBLIC_SUPABASE_URL 을 Pooler URL로 교체:
#   https://[PROJECT].pooler.supabase.com  (서버 측 전용)
# 단, 클라이언트 측은 일반 URL을 써야 하므로 별도 SERVER_SUPABASE_URL 도입을
# 검토하거나 Vercel 환경변수에서만 교체하는 것을 권장.
